}

@incollection{schooley_thermometric_1972,
  title = {Thermometric {{Fixed Points Using Superconductivity}}},
  booktitle = {Advances in {{Cryogenic Engineering}}: {{A Collection}} of {{Invited Papers}} and {{Contributed Papers Presented}} at {{National Technical Meetings During}} 1970 and 1971},
  author = {Schooley, J. F. and Soulen, R. J.},
  editor = {Timmerhaus, K. D.},
  year = {1972},
  series = {Advances in {{Cryogenic Engineering}}},
  pages = {192--198},
