@incollection{RAINER1986371,
title = {Chapter 4: Principles of AB Initio Calculations of Superconducting Transition Temperatures},
editor = {D.F. Brewer},
series = {Progress in Low Temperature Physics},
publisher = {Elsevier},
volume = {10},
pages = {371-424},
year = {1986},
issn = {0079-6417},
doi = {https://doi.org/10.1016/S0079-6417(08)60024-4},
url = {https://www.sciencedirect.com/science/article/pii/S0079641708600244},
author = {Dierk Rainer},
abstract = {Publisher Summary
This chapter discusses the concepts and strategies for an ab initio theory. The standard strategy for setting up an ab initio calculation of superconducting parameters is guided by the existence of two well-separated energy scales in a conventional metal. The ab initio theory needs to be mastered by many-body and band structure theorists. The following calculational procedure is correct to leading order in the ratio of low and high energies. First, one keeps the phonons frozen in, omits all superconducting correlations and solves the high-energy problem of Coulomb-interacting electrons in the fixed potential of the nuclear charges. This part of the ab initio theory needs to be mastered by many-body and band structure theorists. The low-energy problem is solved by the strong-coupling theory of superconductivity. Many-body theory is of central importance in a first-principles approach to superconductivity for three reasons: (1) it explains why one-particle theories, as band-structure theory or the weak- and strong-coupling theories of superconductivity, work for the correlated many-particle system of conduction electrons in a metal, (2) many-body theory develops a calculation scheme, and (3) many-body theory calculates important input material parameters of the theory of superconductivity.}
}

