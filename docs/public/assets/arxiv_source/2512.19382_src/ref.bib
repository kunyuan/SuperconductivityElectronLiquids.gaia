@article{wilson1,
  title = {Renormalization {{Group}} and {{Critical Phenomena}}. {{II}}. {{Phase-Space Cell Analysis}} of {{Critical Behavior}}},
  author = {Wilson, Kenneth G.},
  year = {1971},
  month = nov,
  journal = {Physical Review B},
  volume = {4},
  number = {9},
  pages = {3184--3205},
  publisher = {American Physical Society},
  doi = {10.1103/PhysRevB.4.3184},
  urldate = {2024-10-09},
  abstract = {A generalization of the Ising model is solved, qualitatively, for its critical behavior. In the generalization the spin {$S\rightarrow$}n at a lattice site {$\rightarrow$}n can take on any value from -{$\infty$} to {$\infty$}. The interaction contains a quartic term in order not to be pure Gaussian. The interaction is investigated by making a change of variable {$S\rightarrow$}n={$\Sigma$}⁢{$m$}⁢{$\psim$}⁡(n)⁢{$S\primem$}, where the functions {$\psim$}⁡({$\rightarrow$}n) are localized wavepacket functions. There are a set of orthogonal wave-packet functions for each order-of-magnitude range of the momentum {$\rightarrow$}k. An effective interaction is defined by integrating out the wave-packet variables with momentum of order 1, leaving unintegrated the variables with momentum {$<$}0.5. Then the variables with momentum between 0.25 and 0.5 are integrated, etc. The integrals are computed qualitatively. The result is to give a recursion formula for a sequence of effective Landau-Ginsberg-type interactions. Solution of the recursion formula gives the following exponents: , , for three dimensions. In five dimensions or higher one gets , , and , as in the Gaussian model (at least for a small quartic term). Small corrections neglected in the analysis may make changes (probably small) in the exponents for three dimensions., This article appears in the following collection:},
}

@article{wilson2,
  title = {Renormalization {{Group}} and {{Critical Phenomena}}. {{I}}. {{Renormalization Group}} and the {{Kadanoff Scaling Picture}}},
  author = {Wilson, Kenneth G.},
  year = {1971},
  month = nov,
  journal = {Physical Review B},
  volume = {4},
  number = {9},
  pages = {3174--3183},
  publisher = {American Physical Society},
  doi = {10.1103/PhysRevB.4.3174},
  urldate = {2024-10-09},
  abstract = {The Kadanoff theory of scaling near the critical point for an Ising ferromagnet is cast in differential form. The resulting differential equations are an example of the differential equations of the renormalization group. It is shown that the Widom-Kadanoff scaling laws arise naturally from these differential equations if the coefficients in the equations are analytic at the critical point. A generalization of the Kadanoff scaling picture involving an "irrelevant" variable is considered; in this case the scaling laws result from the renormalization-group equations only if the solution of the equations goes asymptotically to a fixed point., This article appears in the following collection:},
}

@article{wilson3,
  title = {The Renormalization Group: {{Critical}} Phenomena and the {{Kondo}} Problem},
  shorttitle = {The Renormalization Group},
  author = {Wilson, Kenneth G.},
  year = {1975},
  month = oct,
  journal = {Reviews of Modern Physics},
  volume = {47},
  number = {4},
  pages = {773--840},
  publisher = {American Physical Society},
  doi = {10.1103/RevModPhys.47.773},
  urldate = {2024-10-09},
  abstract = {This review covers several topics involving renormalization group ideas. The solution of the {$s$}-wave Kondo Hamiltonian, describing a single magnetic impurity in a nonmagnetic metal, is explained in detail. See Secs. VII-IX. "Block spin" methods, applied to the two dimensional Ising model, are explained in Sec. VI. The first three sections give a relatively short review of basic renormalization group ideas, mainly in the context of critical phenomena. The relationship of the modern renormalization group to the older problems of divergences in statistical mechanics and field theory and field theoretic renormalization is discussed in Sec. IV. In Sec. V the special case of "marginal variables" is discussed in detail, along with the relationship of the modern renormalization group to its original formulation by Gell-Mann and Low and others.},
}

