  publisher = {The Physical Society of Japan},
  issn = {0031-9015},
  doi = {10.1143/JPSJ.74.1345},
  urldate = {2024-05-20},
  abstract = {Both experimental and theoretical approaches in our search for superconductivity under pressure are reviewed. We have developed a double extreme condition of very low-temperature down to 50 mK using a 3 He/ 4 He dilution refrigerator and ultrahigh pressure up to 200 GPa using a diamond-anvil cell (DAC). Experimental techniques producing ultrahigh pressure as well as measuring electrical resistance, magnetization and optical response are developed especially for studying the pressure-induced superconductivity of simple systems such as elemental materials. The details of these techniques are described in {\S}1. In {\S}2, we review several examples of pressure-induced superconductivity observed for the first time by our group. Comparisons between experimental results and theories based on the first principles band calculations are given in {\S}3. Finally, we point out remaining problems to be solved in further studies in the search for pressure-induced superconductivity.},
  keywords = {diamond anvil cell,elemental material,high pressure,low temperature,superconductivity},
}

