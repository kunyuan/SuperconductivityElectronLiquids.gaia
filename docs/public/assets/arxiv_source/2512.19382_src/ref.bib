@article{shimizu_pressure-induced_2005,
  title = {Pressure-Induced {{Superconductivity}} in {{Elemental Materials}}},
  author = {Shimizu, Katsuya and Amaya, Kiichi and Suzuki, Naoshi},
  year = {2005},
  month = may,
  journal = {Journal of the Physical Society of Japan},
