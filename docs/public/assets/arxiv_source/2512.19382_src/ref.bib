  doi = {10.1103/PhysRevB.72.075422},
  urldate = {2024-04-17},
  abstract = {We have studied the {\textasciimacron}{$\Gamma$} surface state on the Mg(0001) surface by angle-resolved photoemission spectroscopy. An analysis of the temperature-dependent linewidth of this state within the Debye model yields a value of {$\lambda$}=0.27(2) for the electron-phonon coupling constant which is in good agreement with available data for bulk Mg. The electron-electron+electron-defect scattering contribution is found by subtracting the electron-phonon contribution from the measured hole linewidth. Its value compares well with the computed result. The analysis of the role of two- and three-dimensional effects in the hole dynamics shows that interband transitions from bulk states to the hole are the dominant mechanism of the hole decay.},
}

